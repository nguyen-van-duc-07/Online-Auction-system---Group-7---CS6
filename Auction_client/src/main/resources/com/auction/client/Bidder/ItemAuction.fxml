<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="900.0" stylesheets="@../Admin/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.screenhandler.ItemAuctionController">

    <top>
        <BorderPane prefHeight="80.0" style="-fx-background-color: #ffffff; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;" styleClass="root" BorderPane.alignment="CENTER">
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
            <left>
                <Button mnemonicParsing="false" onAction="#gotoSellerHome" style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15 8 15; -fx-cursor: hand; -fx-font-weight: bold;" text="Quản lý hàng giao bán" textFill="#2980b9" BorderPane.alignment="CENTER" />
            </left>
            <right>
                <HBox alignment="CENTER_RIGHT" spacing="15.0" BorderPane.alignment="CENTER">
                    <children>
                        <Button mnemonicParsing="false" onAction="#gotoResult" prefHeight="35.0" style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15 8 15; -fx-cursor: hand; -fx-font-weight: bold;" text="Kết quả đấu giá" textFill="#333333" />
                        <MenuButton mnemonicParsing="false" style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 4 10 4 10; -fx-cursor: hand; -fx-font-weight: bold;" text="Profile">
                            <items>
                                <MenuItem mnemonicParsing="false" onAction="#gotoProfile" text="Thông tin" />
                                <MenuItem mnemonicParsing="false" onAction="#gotoLogin" text="Đăng xuất" />
                                <MenuItem mnemonicParsing="false" onAction="#gotoWallet" text="Ví người dùng" />
                            </items>
                        </MenuButton>
                    </children>
                </HBox>
            </right>
            <center>
                <Hyperlink onAction="#gotoHomeWithHyperLink" style="-fx-border-color: transparent;" text="ĐẤU GIÁ 88" textFill="#009900" BorderPane.alignment="CENTER">
                    <font>
                        <Font name="System Bold" size="40.0" />
                    </font>
                </Hyperlink>
            </center>
        </BorderPane>
    </top>

    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: #f4f6f9;">
            <content>
            <HBox alignment="CENTER" spacing="25.0">
               <children>

                               <VBox spacing="5" styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <AreaChart fx:id="priceChart" title="Biểu đồ giá (Triệu)">
                          <xAxis>
                            <CategoryAxis side="BOTTOM" />
                          </xAxis>
                          <yAxis>
                            <NumberAxis forceZeroInRange="false" side="LEFT" />
                          </yAxis>
                        </AreaChart>
                     </children>
                         </VBox>

                              <!-- RIGHT: INFO CARD -->
                        <VBox maxHeight="Infinity" maxWidth="Infinity" spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-border-radius: 10; -fx-background-radius: 10; -fx-border-color: #ddd;" styleClass="card" HBox.hgrow="ALWAYS">
                            <Label fx:id="itemNameLabel" style="-fx-font-size: 24; -fx-font-weight: bold;" text="Tên Sản Phẩm" wrapText="true" />

                                  <Label fx:id="currentPriceField" style="-fx-text-fill: #e67e22; -fx-font-size: 18; -fx-font-weight: bold;" text="Giá hiện tại: 10,000,000 VNĐ" />

                                  <Label fx:id="timeRemainingLabel" style="-fx-text-fill: #2980b9; -fx-font-size: 14;" text="Thời gian còn lại: " />

                                  <Label fx:id="highestBidderLabel" style="-fx-text-fill: #7f8c8d;" text="Người ra giá cao nhất hiện tại: DatGB" />
                             <Label style="-fx-font-weight: bold;" text="Mô tả sản phẩm:" />
                             <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                                 <content>
                                     <Label fx:id="descriptionField" style="-fx-text-fill: #555;" text="Mô tả chi tiết sản phẩm sẽ hiển thị ở đây..." wrapText="true" />
                                 </content>
                             </ScrollPane>
   
                                  <HBox alignment="CENTER_LEFT" spacing="10">
                                <TextField fx:id="bidAmountField" prefHeight="40" promptText="Nhập mức giá..." style="-fx-border-radius: 5;" HBox.hgrow="ALWAYS" />
                                <Button fx:id="placeBidButton" onAction="#placeBid" prefHeight="40" prefWidth="120.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" text="Đấu Giá" />
                            </HBox>
                     <Label fx:id="errorLabel" textFill="#e74c3c" wrapText="true">
                        <font>
                           <Font name="System Italic" size="12.0" />
                        </font>
                        <VBox.margin>
                           <Insets top="5.0" />
                        </VBox.margin>
                     </Label>
                        </VBox>
               </children>
               <padding>
                  <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
               </padding>
            </HBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
