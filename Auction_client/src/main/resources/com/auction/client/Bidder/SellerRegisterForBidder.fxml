<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="653.0" prefWidth="690.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.screenhandler.SellerRegisterForBidderController">
    <children>
        <AnchorPane prefHeight="80.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 2);" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Button layoutX="25.0" layoutY="22.0" mnemonicParsing="false" onAction="#gotoHome" style="-fx-background-color: white; -fx-border-color: #dee2e6; -fx-border-radius: 5; -fx-cursor: hand;" text="← Quay lại" textFill="#6c757d">
                    <font>
                        <Font name="System" size="14.0" />
                    </font>
                </Button>
                <Label alignment="CENTER" layoutX="203.0" layoutY="20.0" prefHeight="38.0" prefWidth="306.0" text="ĐĂNG KÝ NGƯỜI BÁN" textFill="#28a745" AnchorPane.leftAnchor="203.0" AnchorPane.rightAnchor="181.0">
                    <font>
                        <Font name="System Bold" size="26.0" />
                    </font>
                </Label>
            </children>
        </AnchorPane>

        <VBox alignment="TOP_CENTER" layoutY="100.0" prefWidth="900.0" spacing="20.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>
                <VBox maxWidth="550.0" prefWidth="550.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 20, 0, 0, 10);">
                    <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
                    </padding>
                    <children>
                        <VBox spacing="8.0">
                            <children>
                                <Label text="Tên cửa hàng / Thương hiệu" textFill="#495057">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="brandNameField" prefHeight="45.0" promptText="Nhập tên shop của bạn" style="-fx-background-radius: 8; -fx-border-color: #dee2e6; -fx-border-radius: 8;" />
                            </children>
                        </VBox>
                        <VBox spacing="8.0">
                            <children>
                                <Label text="Số CCCD/CMND" textFill="#495057">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="citizenIdentityCardField" prefHeight="45.0" promptText="Nhập 12 số định danh" style="-fx-background-radius: 8; -fx-border-color: #dee2e6; -fx-border-radius: 8;" />
                            </children>
                        </VBox>
                        <VBox spacing="8.0">
                            <children>
                                <Label text="Địa chỉ kho hàng" textFill="#495057">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="locationField" prefHeight="45.0" promptText="Số nhà, tên đường, quận/huyện..." style="-fx-background-radius: 8; -fx-border-color: #dee2e6; -fx-border-radius: 8;" />
                            </children>
                        </VBox>
                        <VBox spacing="8.0">
                            <children>
                                <Label text="Thông tin thanh toán" textFill="#495057">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <HBox spacing="15.0">
                                    <children>
                                        <TextField fx:id="bankAccountField" prefHeight="45.0" prefWidth="280.0" promptText="Số tài khoản ngân hàng" style="-fx-background-radius: 8; -fx-border-color: #dee2e6; -fx-border-radius: 8;" />
                                        <TextField fx:id="bankNameField" prefHeight="45.0" prefWidth="180.0" promptText="Ngân hàng" style="-fx-background-radius: 8; -fx-border-color: #dee2e6; -fx-border-radius: 8;" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <Button mnemonicParsing="false" onAction="#handleRegister" prefHeight="50.0" prefWidth="470.0" style="-fx-background-color: #28a745; -fx-background-radius: 10; -fx-cursor: hand;" text="XÁC NHẬN ĐĂNG KÝ" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                        </Button>
                        <Label alignment="CENTER" prefWidth="470.0" text="Yêu cầu của bạn sẽ được phê duyệt trong vòng 24h" textFill="#95a5a6">
                            <font>
                                <Font name="System Italic" size="12.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
