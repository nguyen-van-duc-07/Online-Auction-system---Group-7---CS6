<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: #f1f5f9;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.screenhandler.PaymentScreenController">
    <children>
        <!-- Header Bar -->
        <AnchorPane prefHeight="70.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(148,163,184,0.08), 10, 0, 0, 2); -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label alignment="CENTER" layoutY="18.0" mouseTransparent="true" text="XÁC NHẬN THANH TOÁN" textFill="#0f172a" AnchorPane.leftAnchor="150.0" AnchorPane.rightAnchor="150.0">
                    <font><Font name="System Bold" size="22.0" /></font>
                </Label>

                <Button fx:id="btnBack" layoutY="18.0" mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-padding: 8 16; -fx-cursor: hand;" text="← Quay lại" AnchorPane.leftAnchor="25.0">
                    <font><Font name="System" size="13.0" /></font>
                </Button>

                <Button fx:id="btnCancelOrder" layoutY="18.0" mnemonicParsing="false" onAction="#handleCancel" style="-fx-background-color: #fef2f2; -fx-border-color: #fca5a5; -fx-border-radius: 8; -fx-text-fill: #ef4444; -fx-font-weight: bold; -fx-padding: 8 16; -fx-cursor: hand;" text="Hủy đơn hàng" AnchorPane.rightAnchor="25.0">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </children>
        </AnchorPane>

        <!-- Main Content Area -->
        <HBox layoutY="105.0" spacing="35.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="105.0">
            <children>
                <!-- Left Column: Shipping Details Form -->
                <VBox spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(148,163,184,0.06), 20, 0, 0, 4);" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
                    <children>
                        <VBox spacing="6.0">
                            <children>
                                <Label text="📍 THÔNG TIN NHẬN HÀNG" textFill="#0f172a">
                                    <font><Font name="System Bold" size="17.0" /></font>
                                </Label>
                                <Label text="Vui lòng kiểm tra kỹ thông tin giao hàng để hệ thống vận chuyển chính xác." textFill="#64748b">
                                    <font><Font size="13.0" /></font>
                                </Label>
                            </children>
                            <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                        </VBox>

                        <VBox spacing="18.0" VBox.vgrow="ALWAYS">
                            <children>
                                <!-- Field: Full Name -->
                                <VBox spacing="6.0">
                                    <children>
                                        <Label text="Họ và tên người nhận" textFill="#475569">
                                            <font><Font name="System Bold" size="13.0" /></font>
                                        </Label>
                                        <TextField fx:id="txtFullName" prefHeight="45.0" promptText="Họ và tên đầy đủ..." style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 12;" />
                                    </children>
                                </VBox>

                                <!-- Field: Phone Number -->
                                <VBox spacing="6.0">
                                    <children>
                                        <Label text="Số điện thoại liên hệ" textFill="#475569">
                                            <font><Font name="System Bold" size="13.0" /></font>
                                        </Label>
                                        <TextField fx:id="txtPhoneNumber" prefHeight="45.0" promptText="Số điện thoại di động..." style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 12;" />
                                    </children>
                                </VBox>

                                <!-- Field: Address -->
                                <VBox spacing="6.0">
                                    <children>
                                        <Label text="Địa chỉ nhận hàng chi tiết" textFill="#475569">
                                            <font><Font name="System Bold" size="13.0" /></font>
                                        </Label>
                                        <TextField fx:id="txtAddress" prefHeight="45.0" promptText="Số nhà, tên đường, phường/xã, quận/huyện, tỉnh/thành phố..." style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 12;" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <!-- Right Column: Order Summary & Checkout -->
                <VBox maxWidth="380.0" minWidth="380.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(148,163,184,0.06), 20, 0, 0, 4);">
                    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
                    <children>
                        <Label text="📦 TÓM TẮT ĐƠN HÀNG" textFill="#0f172a">
                            <font><Font name="System Bold" size="17.0" /></font>
                        </Label>
                        <Separator style="-fx-background-color: #e2e8f0; -fx-opacity: 0.5;" />
                        
                        <!-- Product Item Highlight Box -->
                        <VBox spacing="10.0" style="-fx-background-color: #f8fafc; -fx-background-radius: 12; -fx-padding: 15; -fx-border-color: #f1f5f9; -fx-border-width: 1; -fx-border-radius: 12;">
                            <children>
                                <HBox spacing="10.0">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="lblItemName" text="Sản phẩm đấu giá" textFill="#1e293b" wrapText="true">
                                                    <font><Font name="System Bold" size="15.0" /></font>
                                                </Label>
                                                <Label fx:id="lblOrderId" text="Mã đơn hàng: N/A" textFill="#64748b">
                                                    <font><Font size="12.0" /></font>
                                                </Label>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <Separator style="-fx-background-color: #e2e8f0; -fx-opacity: 0.5;" />
                        
                        <!-- Invoice Price Breakdowns -->
                        <VBox spacing="12.0">
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Giá chốt phiên" textFill="#64748b">
                                            <font><Font size="13.0" /></font>
                                        </Label>
                                        <VBox HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblFinalPrice" text="0đ" textFill="#334155">
                                            <font><Font name="System Bold" size="14.0" /></font>
                                        </Label>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Tiền đã cọc" textFill="#64748b">
                                            <font><Font size="13.0" /></font>
                                        </Label>
                                        <VBox HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblDepositAmount" text="-0đ" textFill="#ef4444">
                                            <font><Font name="System Bold" size="14.0" /></font>
                                        </Label>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        
                        <Separator style="-fx-background-color: #e2e8f0; -fx-opacity: 0.5;" />
                        
                        <!-- Total Payment Row -->
                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 5 0;">
                            <children>
                                <Label text="TỔNG CỘNG" textFill="#0f172a">
                                    <font><Font name="System Bold" size="15.0" /></font>
                                </Label>
                                <VBox HBox.hgrow="ALWAYS" />
                                <Label fx:id="lblTotalAmount" text="0đ" textFill="#10b981">
                                    <font><Font name="System Bold" size="22.0" /></font>
                                </Label>
                            </children>
                        </HBox>
                        
                        <!-- Primary CTA Button -->
                        <Button fx:id="btnCompletePayment" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="50.0" style="-fx-background-color: linear-gradient(to right, #10b981, #059669); -fx-background-radius: 12; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16.0; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(16,185,129,0.15), 10, 0, 0, 4);" text="HOÀN TẤT THANH TOÁN">
                            <VBox.margin><Insets top="10.0" /></VBox.margin>
                        </Button>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>
