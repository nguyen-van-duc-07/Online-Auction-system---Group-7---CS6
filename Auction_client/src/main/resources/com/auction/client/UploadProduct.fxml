<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <BorderPane prefHeight="80.0" style="-fx-background-color: #ffffff; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>

            <left>
                <Button mnemonicParsing="false" style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15 8 15; -fx-cursor: hand; -fx-font-weight: bold;" text="Switch to Bidder Mode" textFill="#2980b9" BorderPane.alignment="CENTER" />
            </left>

            <center>
                <Label text="ĐẤU GIÁ 88" textFill="#009900" BorderPane.alignment="CENTER">
                    <font>
                        <Font name="System Bold" size="40.0" />
                    </font>
                </Label>
            </center>

            <right>
                <HBox alignment="CENTER_RIGHT" spacing="15.0" BorderPane.alignment="CENTER">
                    <children>
                        <Button mnemonicParsing="false" prefHeight="35.0" prefWidth="136.0" style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15 8 15; -fx-cursor: hand; -fx-font-weight: bold;" text="Kết quả đấu giá" textFill="#333333" />
                        <MenuButton mnemonicParsing="false" style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 4 10 4 10; -fx-cursor: hand; -fx-font-weight: bold;" text="Profile">
                            <items>
                                <MenuItem mnemonicParsing="false" text="Thông tin" />
                                <MenuItem mnemonicParsing="false" text="Đăng xuất" />
                                <MenuItem mnemonicParsing="false" text="Ví người dùng" />
                            </items>
                        </MenuButton>
                    </children>
                </HBox>
            </right>
        </BorderPane>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #f4f6f9;" BorderPane.alignment="CENTER">
            <content>
                <VBox alignment="TOP_CENTER" spacing="25.0" style="-fx-background-color: #f4f6f9;">
                    <padding>
                        <Insets bottom="50.0" left="50.0" right="50.0" top="30.0" />
                    </padding>
                    <children>

                        <Label text="Đăng Sản Phẩm Đấu Giá">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>

                        <HBox alignment="TOP_CENTER" spacing="40.0">
                            <children>
                                <VBox spacing="15.0">
                                    <children>
                                        <Label text="Hình ảnh sản phẩm">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <StackPane prefHeight="300.0" prefWidth="300.0" style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-style: dashed; -fx-border-width: 2;">
                                            <children>
                                                <VBox alignment="CENTER" spacing="10.0">
                                                    <children>
                                                        <ImageView fx:id="imagePreview" fitHeight="200.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                                                        <Button mnemonicParsing="false" style="-fx-background-color: #eeeeee; -fx-border-color: #999999; -fx-cursor: hand;" text="Chọn ảnh từ máy tính" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </StackPane>
                                        <Label text="* Hỗ trợ định dạng: JPG, PNG (Tối đa 5MB)" textFill="#7f8c8d">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>

                                <VBox prefWidth="450.0" spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 20; -fx-border-color: #e0e0e0; -fx-background-radius: 8; -fx-border-radius: 8;">
                                    <children>
                                        <Label text="Thông tin cơ bản">
                                            <font>
                                                <Font name="System Bold" size="16.0" />
                                            </font>
                                        </Label>

                                        <VBox spacing="5.0">
                                            <Label text="Tên sản phẩm" />
                                            <TextField fx:id="txtName" prefHeight="35.0" promptText="VanDuc" />
                                        </VBox>

                                        <HBox spacing="15.0">
                                            <children>
                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                    <Label text="Giá khởi điểm (VNĐ)" />
                                                    <TextField fx:id="txtStartPrice" prefHeight="35.0" promptText="0" />
                                                </VBox>
                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                    <Label text="Bước giá tối thiểu" />
                                                    <TextField fx:id="txtStepPrice" prefHeight="35.0" promptText="10.000" />
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <HBox spacing="15.0">
                                            <children>
                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                    <Label text="Ngày kết thúc" />
                                                    <DatePicker fx:id="dateEnd" prefHeight="35.0" prefWidth="250.0" />
                                                </VBox>
                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                    <Label text="Danh mục" />
                                                    <ComboBox fx:id="cbCategory" prefHeight="35.0" prefWidth="250.0" promptText="-- Chọn --" />
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <VBox spacing="5.0">
                                            <Label text="Mô tả sản phẩm" />
                                            <TextArea fx:id="txtDescription" prefHeight="120.0" promptText="Mô tả tình trạng sản phẩm, xuất xứ..." wrapText="true" />
                                        </VBox>

                                        <Button fx:id="btnUpload" maxWidth="Infinity" mnemonicParsing="false" prefHeight="45.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 5; -fx-cursor: hand;" text="ĐĂNG SẢN PHẨM LÊN SÀN">
                                            <VBox.margin>
                                                <Insets top="10.0" />
                                            </VBox.margin>
                                        </Button>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
