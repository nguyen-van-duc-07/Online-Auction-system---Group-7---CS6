<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="720.0" prefWidth="1200.0"
            style="-fx-background-color: #f5f7fb;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1">

    <!-- ================= HEADER ================= -->

    <top>
        <BorderPane prefHeight="80.0" style="-fx-background-color: #ffffff; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>

            <left>
                <Button mnemonicParsing="false" style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15 8 15; -fx-cursor: hand; -fx-font-weight: bold;" text="Switch to Seller Mode" textFill="#2980b9" BorderPane.alignment="CENTER" />
            </left>

            <right>
                <HBox alignment="CENTER_RIGHT" spacing="15.0" BorderPane.alignment="CENTER">
                    <children>
                        <Button mnemonicParsing="false" prefHeight="35.0" prefWidth="136.0" style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15 8 15; -fx-cursor: hand; -fx-font-weight: bold;" text="Kết quả đấu giá" textFill="#333333" />
                        <MenuButton mnemonicParsing="false" style="-fx-background-color: #ffffff; -fx-border-color: #cccccc; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 4 10 4 10; -fx-cursor: hand; -fx-font-weight: bold;" text="Profile">
                            <items>
                                <MenuItem mnemonicParsing="false" text="Thông tin" />
                                <MenuItem mnemonicParsing="false" text="Đăng xuất" />
                                <MenuItem mnemonicParsing="false" text="Ví người dùng" />
                            </items>
                        </MenuButton>
                    </children>
                </HBox>
            </right>
            <center>
                <Hyperlink style="-fx-border-color: transparent;" text="ĐẤU GIÁ 88" textFill="#009900" BorderPane.alignment="CENTER">
                    <font>
                        <Font name="System Bold" size="40.0" />
                    </font>
                </Hyperlink>
            </center>
        </BorderPane>
    </top>

    <!-- ================= CONTENT ================= -->

    <center>

        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    style="-fx-background-color: transparent;
                           -fx-background: transparent;">

            <content>

                <HBox alignment="CENTER"
                      spacing="35.0"
                      style="-fx-background-color: #f5f7fb;">

                    <padding>
                        <Insets top="40.0"
                                right="40.0"
                                bottom="40.0"
                                left="40.0"/>
                    </padding>

                    <children>

                        <!-- ================= LEFT CARD ================= -->

                        <VBox prefHeight="540.0"
                              prefWidth="500.0"
                              spacing="18.0"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 18;
                                     -fx-border-radius: 18;
                                     -fx-border-color: #ebebeb;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 18, 0, 0, 4);">

                            <padding>
                                <Insets top="25.0"
                                        right="25.0"
                                        bottom="25.0"
                                        left="25.0"/>
                            </padding>

                            <children>

                                <Label text="Biểu đồ giá đấu"
                                       textFill="#2c3e50">
                                    <font>
                                        <Font name="System Bold" size="22.0"/>
                                    </font>
                                </Label>

                                <Separator/>

                                <LineChart animated="false"
                                           createSymbols="true"
                                           legendVisible="false"
                                           prefHeight="430.0"
                                           style="-fx-background-color: transparent;">

                                    <xAxis>
                                        <CategoryAxis side="BOTTOM"/>
                                    </xAxis>

                                    <yAxis>
                                        <NumberAxis autoRanging="true"
                                                    minorTickCount="5"
                                                    side="LEFT"/>
                                    </yAxis>

                                </LineChart>

                            </children>

                        </VBox>

                        <!-- ================= RIGHT CARD ================= -->

                        <VBox prefHeight="540.0"
                              prefWidth="520.0"
                              spacing="20.0"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 18;
                                     -fx-border-radius: 18;
                                     -fx-border-color: #ebebeb;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 18, 0, 0, 4);">

                            <padding>
                                <Insets top="30.0"
                                        right="30.0"
                                        bottom="30.0"
                                        left="30.0"/>
                            </padding>

                            <children>

                                <!-- PRODUCT NAME -->

                                <Label fx:id="productNameLabel"
                                       text="Tên Sản Phẩm"
                                       wrapText="true"
                                       textFill="#1f2937">

                                    <font>
                                        <Font name="System Bold" size="32.0"/>
                                    </font>

                                </Label>

                                <!-- CURRENT PRICE -->

                                <VBox spacing="6.0">

                                    <children>

                                        <Label text="Giá hiện tại"
                                               textFill="#6b7280">

                                            <font>
                                                <Font size="15.0"/>
                                            </font>

                                        </Label>

                                        <Label fx:id="currentPriceLabel"
                                               text="85,000,000 VNĐ"
                                               textFill="#ff6b00">

                                            <font>
                                                <Font name="System Bold" size="30.0"/>
                                            </font>

                                        </Label>

                                    </children>

                                </VBox>

                                <!-- INFO BOXES -->

                                <HBox spacing="15.0">

                                    <children>

                                        <VBox alignment="CENTER_LEFT"
                                              prefWidth="220.0"
                                              spacing="8.0"
                                              style="-fx-background-color: #f8fafc;
                                                     -fx-background-radius: 12;
                                                     -fx-padding: 18;">

                                            <children>

                                                <Label text="Thời gian còn lại"
                                                       textFill="#64748b"/>

                                                <Label fx:id="timeRemainingLabel"
                                                       text="02 : 15 : 39"
                                                       textFill="#2563eb">

                                                    <font>
                                                        <Font name="System Bold" size="22.0"/>
                                                    </font>

                                                </Label>

                                            </children>

                                        </VBox>

                                        <VBox alignment="CENTER_LEFT"
                                              prefWidth="220.0"
                                              spacing="8.0"
                                              style="-fx-background-color: #f8fafc;
                                                     -fx-background-radius: 12;
                                                     -fx-padding: 18;">

                                            <children>

                                                <Label text="Người đấu giá cao nhất"
                                                       textFill="#64748b"/>

                                                <Label fx:id="highestBidderLabel"
                                                       text="DatGB"
                                                       textFill="#111827">

                                                    <font>
                                                        <Font name="System Bold" size="18.0"/>
                                                    </font>

                                                </Label>

                                            </children>

                                        </VBox>

                                    </children>

                                </HBox>

                                <!-- DESCRIPTION -->

                                <VBox spacing="10.0">

                                    <children>

                                        <Label text="Mô tả sản phẩm"
                                               textFill="#1f2937">

                                            <font>
                                                <Font name="System Bold" size="18.0"/>
                                            </font>

                                        </Label>

                                        <Label fx:id="productDescLabel"
                                               prefHeight="120.0"
                                               text="Mô tả chi tiết sản phẩm sẽ hiển thị tại đây..."
                                               textFill="#4b5563"
                                               wrapText="true">

                                            <font>
                                                <Font size="15.0"/>
                                            </font>

                                        </Label>

                                    </children>

                                </VBox>

                                <Region VBox.vgrow="ALWAYS"/>

                                <!-- BID AREA -->

                                <VBox spacing="12.0">

                                    <children>

                                        <Label text="Nhập giá đấu của bạn"
                                               textFill="#374151">

                                            <font>
                                                <Font name="System Bold" size="16.0"/>
                                            </font>

                                        </Label>

                                        <HBox spacing="15.0">

                                            <children>

                                                <TextField fx:id="bidAmountField"
                                                           HBox.hgrow="ALWAYS"
                                                           prefHeight="50.0"
                                                           promptText="Ví dụ: 90,000,000"
                                                           style="-fx-background-radius: 12;
                                                                  -fx-border-radius: 12;
                                                                  -fx-border-color: #d1d5db;
                                                                  -fx-font-size: 15px;
                                                                  -fx-padding: 0 15 0 15;"/>

                                                <Button fx:id="placeBidButton"
                                                        mnemonicParsing="false"
                                                        prefHeight="50.0"
                                                        prefWidth="150.0"
                                                        style="-fx-background-color: linear-gradient(to right, #00b09b, #00c853);
                                                               -fx-text-fill: white;
                                                               -fx-font-weight: bold;
                                                               -fx-font-size: 17px;
                                                               -fx-background-radius: 12;
                                                               -fx-cursor: hand;"
                                                        text="Đấu Giá"/>

                                            </children>

                                        </HBox>

                                    </children>

                                </VBox>

                            </children>

                        </VBox>

                    </children>

                </HBox>

            </content>

        </ScrollPane>

    </center>

</BorderPane>
