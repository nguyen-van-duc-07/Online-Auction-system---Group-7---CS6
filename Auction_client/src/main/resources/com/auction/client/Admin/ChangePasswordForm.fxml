<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox maxWidth="500.0" spacing="20.0" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <Label text="Đổi Mật Khẩu" textFill="#2C3E50">
            <font><Font name="Segoe UI Bold" size="20.0" /></font>
        </Label>
        <Separator />
        <GridPane hgap="15.0" vgap="15.0">
            <columnConstraints>
                <ColumnConstraints minWidth="130.0" prefWidth="150.0" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            <children>
                <Label text="Mật khẩu hiện tại:" GridPane.rowIndex="0">
                    <font><Font name="Segoe UI" size="14.0" /></font>
                </Label>
                <PasswordField fx:id="txtCurrentPassword" style="-fx-background-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Mật khẩu mới:" GridPane.rowIndex="1">
                    <font><Font name="Segoe UI" size="14.0" /></font>
                </Label>
                <PasswordField fx:id="txtNewPassword" style="-fx-background-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Xác nhận mật khẩu:" GridPane.rowIndex="2">
                    <font><Font name="Segoe UI" size="14.0" /></font>
                </Label>
                <PasswordField fx:id="txtConfirmPassword" style="-fx-background-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            </children>
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>
        </GridPane>
        <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 10 0 0 0;">
            <children>
                <Button mnemonicParsing="false" onAction="#handleUpdatePassword" style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-padding: 8 20;" text="Cập nhật mật khẩu">
                    <font><Font name="Segoe UI Bold" size="13.0" /></font>
                </Button>
            </children>
        </HBox>
    </children>
</VBox>
