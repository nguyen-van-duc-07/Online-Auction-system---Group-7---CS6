<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: #f9f9f9;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <TextField prefHeight="35.0" prefWidth="400.0" promptText="Tìm kiếm trong danh sách quản lý..." />
                <Button prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #1b5e20;" text="Tìm kiếm" textFill="WHITE">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Button>
            </children>
        </HBox>

        <Label text="Danh Sách Quản Lý Dữ Liệu" textFill="#333333">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>

        <TableView VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn prefWidth="75.0" text="ID" />
                <TableColumn prefWidth="300.0" text="Tên / Nội dung" />
                <TableColumn prefWidth="150.0" text="Ngày cập nhật" />
                <TableColumn prefWidth="150.0" text="Trạng thái" />
            </columns>
        </TableView>

        <HBox spacing="15.0">
            <children>
                <Button prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #27ae60;" text="Thêm mới" textFill="WHITE">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Button>
                <Button prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #2980b9;" text="Chỉnh sửa" textFill="WHITE">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Button>
                <Button prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #c0392b;" text="Xóa" textFill="WHITE">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Button>
            </children>
        </HBox>
    </children>
</VBox>