<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: #f9f9f9;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.screenhandler.admin.AuctionManagerController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <TextField fx:id="searchField" prefHeight="35.0" prefWidth="400.0" promptText="Tìm kiếm trong danh sách quản lý..." />
                <Button onAction="#handleSearch" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #1b5e20;" text="Tìm kiếm" textFill="WHITE">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Button>
            </children>
        </HBox>

        <Label text="DANH SÁCH QUẢN LÝ PHIÊN ĐẤU GIÁ" textAlignment="CENTER" textFill="#333333">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>

        <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="serialColumn" prefWidth="42.00000190734863" text="STT" />
            <TableColumn fx:id="auctionIdColumn" prefWidth="124.0" text="Id phiên đấu giá" />
                <TableColumn fx:id="itemNameColumn" prefWidth="134.66668701171875" text="Tên" />
                <TableColumn fx:id="startTimeColumn" prefWidth="160.0" text="Thời gian bắt đầu" />
            <TableColumn fx:id="currentHighestPriceColumn" prefWidth="115.33331298828125" text="Giá hiện tại" />
            <TableColumn fx:id="endTimeColumn" prefWidth="116.6666259765625" text="Thời gian kết thúc" />
            <TableColumn fx:id="statusColumn" prefWidth="74.00002034505201" text="Trạng thái" />
            </columns>
        </TableView>

        <HBox spacing="15.0">
            <children>
                <Button onAction="#handleAdd" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #27ae60;" text="Mở" textFill="WHITE">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Button>
                <Button onAction="#handleEdit" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #2980b9;" text="Chỉnh sửa" textFill="WHITE">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Button>
                <Button onAction="#handleDelete" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #c0392b;" text="Xóa" textFill="WHITE">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Button>
            </children>
        </HBox>
    </children>
</VBox>
