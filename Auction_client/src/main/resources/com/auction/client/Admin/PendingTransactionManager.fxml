<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="20.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.screenhandler.admin.PendingTransactionManagerController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <children>
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <children>
                    <Label text="Quản lý giao dịch nạp/rút tiền" textFill="#2c3e50">
                        <font>
                            <Font name="System Bold" size="24.0" />
                        </font>
                    </Label>
                    <Label text="Duyệt các yêu cầu nạp tiền hoặc rút tiền từ người dùng" textFill="#7f8c8d">
                        <font>
                            <Font size="14.0" />
                        </font>
                    </Label>
                </children>
            </VBox>
            <Button onAction="#handleReload" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #2980b9; -fx-background-radius: 5; -fx-cursor: hand;" text="🔄 Làm mới" textFill="WHITE">
                <font><Font name="System Bold" size="12.0" /></font>
            </Button>
        </children>
    </HBox>

    <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" prefWidth="250.0" text="Mã Giao dịch" />
            <TableColumn fx:id="colWalletId" prefWidth="200.0" text="Mã Ví" />
            <TableColumn fx:id="colType" prefWidth="100.0" text="Loại" />
            <TableColumn fx:id="colAmount" prefWidth="150.0" text="Số tiền" />
            <TableColumn fx:id="colAction" prefWidth="150.0" text="Hành động" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

</VBox>
