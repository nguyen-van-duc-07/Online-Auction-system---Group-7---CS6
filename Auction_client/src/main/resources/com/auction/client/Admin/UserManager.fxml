<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: #fffdf9;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.screenhandler.admin.UserManagerController">
    <children>
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #1b5e20; -fx-padding: 10; -fx-background-radius: 5;">
            <children>
                <Label text="DANH SÁCH QUẢN LÝ NGƯỜI DÙNG" textFill="WHITE">
                    <font><Font name="System Bold" size="16.0" /></font>
                </Label>
            </children>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <TextField fx:id="searchField" onKeyReleased="#handleSearch" prefHeight="35.0" prefWidth="400.0" promptText="Nhập tên, số điện thoại hoặc email..." />
                <Button onAction="#handleSearch" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #1b5e20;" text="Tìm kiếm" textFill="WHITE">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Button>
            </children>
        </HBox>

        <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="serialColumn" prefWidth="50.0" text="STT" />
                <TableColumn fx:id="realNameColumn" prefWidth="150.0" text="Tên người dùng" />
                <TableColumn fx:id="dobColumn" prefWidth="110.0" text="Ngày sinh" />
                <TableColumn fx:id="phoneNumberColumn" prefWidth="130.0" text="Số điện thoại" />
                <TableColumn fx:id="emailColumn" prefWidth="180.0" text="Email" />
                <TableColumn fx:id="addressColumn" prefWidth="230.0" text="Địa chỉ" />
                <TableColumn fx:id="roleColumn" prefWidth="100.0" text="Vai trò" />
            </columns>
        </TableView>
    </children>
</VBox>
