<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: #fffdf9;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.screenhandler.admin.SellerAccountManagerController">
    <children>
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #f39c12; -fx-padding: 10; -fx-background-radius: 5;">
            <children>
                <Label text="DANH SÁCH ĐƠN ĐĂNG KÝ NGƯỜI BÁN (SELLER)" textFill="WHITE">
                    <font><Font name="System Bold" size="16.0" /></font>
                </Label>
            </children>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <TextField fx:id="searchField" prefHeight="35.0" prefWidth="300.0" promptText="Nhập tên hoặc SĐT người đăng ký..." />
                <Button onAction="#handleSearch" prefHeight="35.0" style="-fx-background-color: #e67e22;" text="Tìm kiếm" textFill="WHITE">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Button>
            </children>
        </HBox>

        <TableView fx:id="sellerProfileTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="serialColumn" prefWidth="40.66665458679199" text="STT" />
            <TableColumn fx:id="createAtColumn" prefWidth="152.66668319702148" text="Ngày tạo" />
                <TableColumn fx:id="userIdColumn" prefWidth="106.66670227050781" text="ID Bidder" />
            <TableColumn fx:id="brandNameColumn" prefWidth="175.33331298828125" text="Tên cửa hàng" />
                <TableColumn fx:id="locationColumn" prefWidth="150.0" text="Địa chỉ" />
                <TableColumn fx:id="bankAccountColumn" prefWidth="127.33331298828125" text="Tài khoản thanh toán" />
                <TableColumn fx:id="bankNameColumn" prefWidth="110.0" text="Ngân hàng" />
            <TableColumn fx:id="citizenIdentityCardColumn" prefWidth="126.0" text="CCCD" />
            <TableColumn fx:id="statusColumn" prefWidth="101.3333740234375" text="Trạng thái" />
            </columns>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="20.0">
            <children>
            <Button onAction="#handleAccept" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #27ae60;" text="CHẤP NHẬN" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Button>
            <Button onAction="#handleReject" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #c0392b;" text="TỪ CHỐI" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Button>
            </children>
        </HBox>
    </children>
</VBox>
