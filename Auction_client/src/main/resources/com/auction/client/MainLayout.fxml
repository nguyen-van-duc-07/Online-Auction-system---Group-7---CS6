<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<StackPane prefHeight="650.0" prefWidth="1050.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.screenhandler.MainLayoutController">

    <BorderPane>
        <!-- ==================== THANH NGANG TRÊN (TOP BAR) ==================== -->
        <top>
            <BorderPane prefHeight="70.0" style="-fx-background-color: #ffffff; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
                <padding><Insets left="25.0" right="25.0" /></padding>

                <left>
                    <Label onMouseClicked="#gotoHomeFeed" style="-fx-cursor: hand;" text="ĐẤU GIÁ 88" textFill="#009900" BorderPane.alignment="CENTER">
                        <font><Font name="System Bold" size="36.0" /></font>
                    </Label>
                </left>

                <center>
                    <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="400.0" prefHeight="42.0" prefWidth="440.0" spacing="10.0" style="-fx-background-color: #f0f2f5; -fx-background-radius: 20; -fx-border-color: #ddd; -fx-border-radius: 20; -fx-padding: 5 15;">
                        <BorderPane.margin>
                            <Insets left="50.0" right="50.0" />
                        </BorderPane.margin>
                        <children>
                            <Label style="-fx-font-size: 16px;" text="🔍" textFill="#888888" />
                            <TextField fx:id="searchField" promptText="Tìm kiếm sản phẩm, phiên đấu giá..." style="-fx-background-color: transparent; -fx-prompt-text-fill: #888888; -fx-font-size: 14px;" HBox.hgrow="ALWAYS" />
                        </children>
                    </HBox>
                </center>

                <right>
                    <HBox alignment="CENTER_RIGHT" spacing="15.0" BorderPane.alignment="CENTER">
                        <children>
                            <VBox alignment="CENTER_RIGHT" spacing="2.0">
                                <children>
                                    <Label fx:id="realNameLabel" style="-fx-font-weight: bold;" text="Chào, Admin" textFill="#555555" />
                                    <Label fx:id="remainingLabel" style="-fx-font-size: 12px; -fx-font-weight: bold;" text="Số dư: 0 đ" textFill="#ff9900" />
                                </children>
                            </VBox>
                            <MenuButton mnemonicParsing="false" style="-fx-background-color: #f8f9fa; -fx-border-color: #ddd; -fx-border-radius: 20; -fx-background-radius: 20;" text="Tài khoản">
                                <items>
                                    <MenuItem mnemonicParsing="false" onAction="#gotoProfile" text="Thông tin" />
                                    <MenuItem mnemonicParsing="false" onAction="#gotoLogin" text="Đăng xuất" />
                                    <MenuItem mnemonicParsing="false" onAction="#gotoWallet" text="Ví người dùng" />
                                </items>
                            </MenuButton>
                        </children>
                    </HBox>
                </right>
            </BorderPane>
        </top>

        <!-- ==================== SIDEBAR TRÁI ==================== -->
        <left>
            <VBox fx:id="sidebar" prefHeight="580.0" prefWidth="235.0" spacing="12.0" style="-fx-background-color: linear-gradient(to bottom, #1e7d32, #009900);" BorderPane.alignment="CENTER">
                <padding><Insets left="15.0" right="15.0" top="30.0" /></padding>
                <children>
                    <!-- Button cố định 1: Quản lý hàng giao bán -->
                    <Button fx:id="btnQuanLy" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#gotoSellerHome" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 15; -fx-background-radius: 12; -fx-cursor: hand;" text="🛒 Quản lý hàng giao bán">
                        <effect><DropShadow blurType="GAUSSIAN" height="10.0" radius="4.5" width="10.0"><color><Color opacity="0.3" /></color></DropShadow></effect>
                    </Button>

                    <!-- Button cố định 2: Kết quả đấu giá -->
                    <Button fx:id="btnKetQua" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#gotoResult" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 15; -fx-background-radius: 12; -fx-cursor: hand;" text="🏆 Kết quả đấu giá" />

                    <!-- ===== VÙNG SIDEBAR ĐỘNG — load button theo ngữ cảnh ===== -->
                    <VBox fx:id="sidebarDynamic" spacing="12.0">
                        <VBox.margin><Insets top="5.0" /></VBox.margin>
                    </VBox>

                    <!-- Spacer đẩy nội dung lên trên -->
                    <Region VBox.vgrow="ALWAYS" />
                </children>
            </VBox>
        </left>

        <!-- ==================== NỘI DUNG CHÍNH (SCROLLPANE) ==================== -->
        <center>
            <ScrollPane fx:id="mainContent" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: #f0f2f5;" vbarPolicy="NEVER" BorderPane.alignment="CENTER">
                <content>
                    <FlowPane fx:id="feedContainer" alignment="TOP_CENTER" hgap="25.0" style="-fx-background-color: #f0f2f5;" vgap="25.0">
                        <padding><Insets bottom="30.0" left="25.0" right="25.0" top="30.0" /></padding>
                    </FlowPane>
                </content>
            </ScrollPane>
        </center>
    </BorderPane>

    <!-- ==================== NÚT THÔNG BÁO NỔI ==================== -->
    <VBox fx:id="floatingIcon" onMouseClicked="#gotoNotifications" maxHeight="-Infinity" maxWidth="-Infinity" style="-fx-background-color: #FFAD00; -fx-background-radius: 50; -fx-padding: 12; -fx-cursor: hand;" StackPane.alignment="BOTTOM_LEFT">
        <StackPane.margin>
            <Insets bottom="30.0" left="30.0" />
        </StackPane.margin>
        <children>
            <StackPane>
                <Label style="-fx-font-size: 26px;" text="🔔" />
                <Label fx:id="notificationBadge" alignment="CENTER"
                       style="-fx-background-color: red; -fx-background-radius: 50;
                       -fx-min-width: 12; -fx-min-height: 12;
                       -fx-max-width: 12; -fx-max-height: 12;"
                       text="" StackPane.alignment="TOP_RIGHT" visible="false">
                    <StackPane.margin>
                        <Insets right="-3.0" top="-3.0" />
                    </StackPane.margin>
                </Label>
            </StackPane>
        </children>
        <effect>
            <DropShadow blurType="GAUSSIAN" color="#00000066" offsetX="2.0" offsetY="2.0" radius="10.0" />
        </effect>
    </VBox>
</StackPane>
