<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #F4FBF4;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <content>
        <VBox alignment="TOP_CENTER" spacing="25.0" style="-fx-padding: 40 30 40 30;">
            <children>

                <VBox alignment="TOP_CENTER" prefHeight="45.0" prefWidth="930.0" spacing="8.0">
                    <children>
                        <Label style="-fx-text-fill: #009900;" text="Đăng Sản Phẩm Đấu Giá" textAlignment="CENTER" textFill="#009900">
                            <font>
                                <Font name="System Bold" size="36.0" />
                            </font>
                        </Label>
                        <Label textAlignment="CENTER" textFill="#64748B">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Label>
                    </children>
                    <VBox.margin>
                        <Insets bottom="10.0" />
                    </VBox.margin>
                </VBox>

                <GridPane hgap="30.0" maxWidth="1000.0" vgap="25.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="320.0" minWidth="280.0" prefWidth="300.0" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="400.0" prefWidth="600.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>

                        <VBox spacing="20.0" GridPane.columnIndex="0" GridPane.valignment="TOP">
                            <children>
                                <VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 20;">
                                    <children>
                                        <Label maxWidth="1.1796493E7" text="Hình ảnh sản phẩm">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>

                                        <VBox alignment="CENTER" prefHeight="200.0" prefWidth="200.0" style="-fx-border-color: #A3D9A5; -fx-border-style: dashed; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-color: #F8FAFC;">
                                            <children>
                                                <Label text="☁" textFill="#64748B">
                                                    <font>
                                                        <Font size="32.0" />
                                                    </font>
                                                </Label>
                                                <Label text="Chọn ảnh từ máy tính" textFill="#334155">
                                                    <font>
                                                        <Font name="System Bold" size="13.0" />
                                                    </font>
                                                </Label>
                                                <Label textFill="#64748B" />
                                            </children>
                                        </VBox>

                                        <Label alignment="CENTER" text="* Hỗ trợ định dạng: JPG, PNG&#10;(Tối đa 5MB)" textAlignment="CENTER" textFill="#64748B">
                                            <font>
                                                <Font size="11.0" />
                                            </font></Label>

                                        <HBox alignment="CENTER" spacing="12.0">
                                            <children>
                                                <Button prefHeight="45.0" prefWidth="45.0" style="-fx-background-color: #F4FBF4; -fx-border-color: #CBD5E1; -fx-border-radius: 6;" text="📷" />
                                                <Button prefHeight="45.0" prefWidth="45.0" style="-fx-background-color: #F4FBF4; -fx-border-color: #CBD5E1; -fx-border-radius: 6;" text="📷" />
                                                <Button prefHeight="45.0" prefWidth="45.0" style="-fx-background-color: #F4FBF4; -fx-border-color: #CBD5E1; -fx-border-radius: 6;" text="📷" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox spacing="8.0" style="-fx-background-color: #E8F5E9; -fx-background-radius: 12; -fx-padding: 18;">
                                    <children>
                                        <Label text="🛡 Mẹo đăng tin" textFill="#2E7D32">
                                            <font>
                                                <Font name="System Bold" size="13.0" />
                                            </font>
                                        </Label>
                                        <Label text="Sản phẩm có hình ảnh thực tế, ánh sáng tốt thường có lượt đấu giá cao hơn 40% so với thông thường." textFill="#2E3A2E" wrapText="true">
                                            <font>
                                                <Font size="12.0" />
                                            </font></Label>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox spacing="22.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 30;" GridPane.columnIndex="1">
                            <children>
                                <Label text="Thông tin cơ bản">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>

                                <VBox spacing="6.0">
                                    <children>
                                        <HBox spacing="4.0">
                                            <children>
                                                <Label text="Tên sản phẩm" />
                                                <Label text="*" textFill="RED" />
                                            </children>
                                        </HBox>
                                        <TextField promptText="Nhập tên sản phẩm đấu giá" style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-color: #FFFFFF;" />
                                    </children>
                                </VBox>

                                <HBox spacing="15.0">
                                    <children>
                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Giá khởi điểm (VNĐ)" />
                                                <HBox alignment="CENTER_RIGHT" style="-fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-color: #FFFFFF; -fx-background-radius: 6;">
                                                    <children>
                                                        <TextField style="-fx-background-color: transparent; -fx-padding: 10;" text="0" HBox.hgrow="ALWAYS" />
                                                        <Label text="VNĐ" textFill="#64748B">
                                                            <padding>
                                                                <Insets right="12.0" />
                                                            </padding>
                                                        </Label>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Bước giá tối thiểu" />
                                                <HBox alignment="CENTER_RIGHT" style="-fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-color: #FFFFFF; -fx-background-radius: 6;">
                                                    <children>
                                                        <TextField style="-fx-background-color: transparent; -fx-padding: 10;" text="10.000" HBox.hgrow="ALWAYS" />
                                                        <Label text="VNĐ" textFill="#64748B">
                                                            <padding>
                                                                <Insets right="12.0" />
                                                            </padding>
                                                        </Label>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox spacing="15.0">
                                    <children>
                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Thời gian bắt đầu" />
                                                <HBox spacing="10.0">
                                                    <children>
                                                        <DatePicker promptText="mm/dd/yyyy" style="-fx-pref-height: 40; -fx-background-color: #FFFFFF; -fx-border-color: #CBD5E1; -fx-border-radius: 6;" HBox.hgrow="ALWAYS" />
                                                        <TextField promptText="--:--" style="-fx-pref-height: 40; -fx-pref-width: 80; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-color: #FFFFFF;" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Thời gian kết thúc" />
                                                <HBox spacing="10.0">
                                                    <children>
                                                        <DatePicker promptText="mm/dd/yyyy" style="-fx-pref-height: 40; -fx-background-color: #FFFFFF; -fx-border-color: #CBD5E1; -fx-border-radius: 6;" HBox.hgrow="ALWAYS" />
                                                        <TextField promptText="--:--" style="-fx-pref-height: 40; -fx-pref-width: 80; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-color: #FFFFFF;" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <VBox spacing="6.0">
                                    <children>
                                        <Label text="Danh mục" />
                                        <ComboBox maxWidth="1.1796493E7" promptText="Chọn danh mục" style="-fx-background-color: #FFFFFF; -fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-padding: 6;" />
                                    </children>
                                </VBox>

                                <VBox spacing="6.0">
                                    <children>
                                        <Label text="Mô tả sản phẩm" />
                                        <TextArea prefHeight="160.0" promptText="Mô tả chi tiết tình trạng sản phẩm, xuất xứ, phụ kiện đi kèm..." style="-fx-border-color: #CBD5E1; -fx-border-radius: 6; -fx-background-color: #FFFFFF;" wrapText="true" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </GridPane>
            </children>
        </VBox>
    </content>
</ScrollPane>