<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<StackPane prefHeight="650.0" prefWidth="1050.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.screenhandler.HomeController">

    <BorderPane>
        <top>
            <BorderPane prefHeight="70.0" style="-fx-background-color: #ffffff; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
                <padding><Insets left="25.0" right="25.0" /></padding>

                <left>
                    <Label onMouseClicked="#gotoHomeFeed" style="-fx-cursor: hand;" text="ĐẤU GIÁ 88" textFill="#009900" BorderPane.alignment="CENTER">
                        <font><Font name="System Bold" size="36.0" /></font>
                    </Label>
                </left>

                <center>
                    <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="400.0" prefHeight="42.0" prefWidth="440.0" spacing="10.0" style="-fx-background-color: #f0f2f5; -fx-background-radius: 20; -fx-border-color: #ddd; -fx-border-radius: 20; -fx-padding: 5 15;">
                        <BorderPane.margin>
                            <Insets left="50.0" right="50.0" />
                        </BorderPane.margin>
                        <children>
                            <Label style="-fx-font-size: 16px;" text="🔍" textFill="#888888" />
                            <TextField fx:id="searchField" promptText="Tìm kiếm sản phẩm, phiên đấu giá..." style="-fx-background-color: transparent; -fx-prompt-text-fill: #888888; -fx-font-size: 14px;" HBox.hgrow="ALWAYS" />
                        </children>
                    </HBox>
                </center>

                <right>
                    <HBox alignment="CENTER_RIGHT" spacing="15.0" BorderPane.alignment="CENTER">
                        <children>

                            <VBox alignment="CENTER_RIGHT" spacing="2.0">
                                <children>
                                    <Label fx:id="realNameLabel" style="-fx-font-weight: bold;" text="Chào, Admin" textFill="#555555" />
                                    <Label fx:id="lblSoDu" style="-fx-font-size: 12px; -fx-font-weight: bold;" text="Số dư: 0 đ" textFill="#ff9900" />
                                </children>
                            </VBox>
                            <MenuButton mnemonicParsing="false" style="-fx-background-color: #f8f9fa; -fx-border-color: #ddd; -fx-border-radius: 20; -fx-background-radius: 20;" text="Tài khoản">
                                <items>
                                    <MenuItem mnemonicParsing="false" onAction="#gotoProfile" text="Thông tin" />
                                    <MenuItem mnemonicParsing="false" onAction="#gotoLogin" text="Đăng xuất" />
                                    <MenuItem mnemonicParsing="false" onAction="#gotoWallet" text="Ví người dùng" />
                                </items>
                            </MenuButton>
                        </children>
                    </HBox>
                </right>
            </BorderPane>
        </top>

        <left>
            <VBox fx:id="sidebar" prefHeight="580.0" prefWidth="235.0" spacing="12.0" style="-fx-background-color: linear-gradient(to bottom, #1e7d32, #009900);" BorderPane.alignment="CENTER">
                <padding><Insets left="15.0" right="15.0" top="30.0" /></padding>
                <children>

                    <Button fx:id="btnQuanLy" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#gotoSellerHome" style="-fx-background-color: white; -fx-text-fill: #1e7d32; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 15; -fx-background-radius: 12; -fx-cursor: hand;" text="🛒 Quản lý hàng giao bán">
                        <effect><DropShadow blurType="GAUSSIAN" height="10.0" radius="4.5" width="10.0"><color><Color opacity="0.3" /></color></DropShadow></effect>
                    </Button>

                    <Button fx:id="btnPhienDangChay" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleGetMyActiveAuctions" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 15; -fx-background-radius: 12; -fx-cursor: hand;" text="⚡ Phiên đang đấu giá" />

                    <Label fx:id="lblStatusHeader" text="QUẢN LÝ ĐƠN HÀNG" textFill="#c8e6c9">
                        <VBox.margin><Insets bottom="5.0" left="10.0" top="25.0" /></VBox.margin>
                        <font><Font name="System Bold" size="11.0" /></font>
                    </Label>

                    <Button fx:id="btnChoGiaoHang" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleGetPendingOrders" style="-fx-background-color: transparent; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 10; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15; -fx-cursor: hand;" text="📦 Đơn hàng chờ giao">
                        <font><Font name="System Bold" size="12.0" /></font>
                    </Button>

                    <Button fx:id="btnDaHoanThanh" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleGetCompletedOrders" style="-fx-background-color: transparent; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 10; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15; -fx-cursor: hand;" text="✅ Giao dịch thành công">
                        <font><Font name="System Bold" size="12.0" /></font>
                    </Button>

                    <Button fx:id="btnDonHuy" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleGetCanceledOrders" style="-fx-background-color: transparent; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 10; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15; -fx-cursor: hand;" text="❌ Phiên lỗi / Huỷ đơn">
                        <font><Font name="System Bold" size="12.0" /></font>
                    </Button>

                    <Region VBox.vgrow="ALWAYS" />
                </children>
            </VBox>
        </left>

        <center>
            <ScrollPane fx:id="mainContent" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: #f0f2f5;" vbarPolicy="NEVER" BorderPane.alignment="CENTER">
                <content>
                    <VBox spacing="10.0" style="-fx-background-color: #f0f2f5;">
                        <padding><Insets bottom="30.0" left="25.0" right="25.0" top="25.0" /></padding>
                        <children>

                            <HBox fx:id="addProductCard" alignment="CENTER" onMouseClicked="#gotoSellerHome" prefHeight="70.0" style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #e0e0e0; -fx-border-radius: 10; -fx-border-width: 1; -fx-cursor: hand; -fx-padding: 15;">
                                <children>
                                    <HBox alignment="CENTER" spacing="10.0">
                                        <children>
                                            <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="+" textFill="#009900" />
                                            <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Đăng sản phẩm lên sàn" textFill="#009900" />
                                        </children>
                                    </HBox>
                                </children>
                                <effect>
                                    <DropShadow blurType="GAUSSIAN" color="#0000000d" height="8.0" offsetY="2.0" radius="3.5" width="8.0" />
                                </effect>
                            </HBox>

                            <FlowPane fx:id="feedContainer" alignment="TOP_CENTER" hgap="25.0" style="-fx-background-color: #f0f2f5;" vgap="25.0">
                                <VBox.margin>
                                    <Insets top="15.0" />
                                </VBox.margin>
                            </FlowPane>

                        </children>
                    </VBox>
                </content>
            </ScrollPane>
        </center>
    </BorderPane>
</StackPane>
