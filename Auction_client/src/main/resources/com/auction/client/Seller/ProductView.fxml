<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="303.0" prefWidth="851.0" spacing="40.0" style="-fx-background-color: #F8F9FA;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ProductController">
    <children>

        <VBox alignment="CENTER" minHeight="263.0" minWidth="311.0" prefHeight="263.0" prefWidth="311.0" style="-fx-background-color: #F1F3F5; -fx-background-radius: 12; -fx-border-radius: 12;">
            <children>
                <ImageView fx:id="productImageView" fitHeight="250.0" fitWidth="250.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@placeholder_icon.png" />
                    </image>
                </ImageView>
            </children>
        </VBox>

        <VBox alignment="CENTER_LEFT" prefHeight="400.0" prefWidth="420.0" spacing="16.0">
            <children>

                <Label alignment="CENTER" prefHeight="26.0" prefWidth="90.0" style="-fx-background-color: #00A619; -fx-background-radius: 20;" text="Đang diễn ra" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="11.0" />
                    </font>
                </Label>

                <VBox spacing="2.0">
                    <children>
                        <Label fx:id="productNameMainLabel" text="Tên SP" textFill="#1A1D20">
                            <font>
                                <Font name="System Bold" size="32.0" />
                            </font>
                        </Label>
                        <Label fx:id="productNameSubLabel" text="Tên shop" textFill="#00A619">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <Label fx:id="productDescriptionLabel" text="Thong tin sp" textFill="#495057" wrapText="true">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>

                <HBox spacing="15.0">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </HBox>

            </children>
        </VBox>

    </children>
    <padding>
        <Insets left="40.0" right="40.0" />
    </padding>
</HBox>
